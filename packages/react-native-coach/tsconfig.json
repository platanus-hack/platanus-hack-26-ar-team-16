{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-native",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": false,
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": []
  },
  "include": [
    "src/**/*",
    "../../src/**/*",
    "../../nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "../../node_modules",
    "../../app",
    "../../src/components/StandaloneCoachProvider.tsx",
    "../../src/services/supabase.ts"
  ]
}
