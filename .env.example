# ──────────────────────────────────────────────────────────
# Public (bundled into the Expo client — safe for frontend)
# ──────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_APP_ENV=development

# Build-time tenant slug — each tenant ships as its own app. Drives the brand
# identity (colors, surfaces, copy) from the very first paint, including the
# login screen. One of: `default`, `smartfit`, `megatlon`. Defaults to
# `megatlon` if unset (the hackathon demo build).
EXPO_PUBLIC_TENANT_SLUG=megatlon

# Server-side default tenant for new signups (used by signUpWithEmail when no
# tenant_slug metadata is provided). Usually matches EXPO_PUBLIC_TENANT_SLUG.
EXPO_PUBLIC_DEFAULT_TENANT=megatlon

# ──────────────────────────────────────────────────────────
# Server-only (set as Edge Function secrets via `supabase
# secrets set ...`, NEVER inline in client code)
# ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=...   (auto-injected by Supabase, do not set manually)
